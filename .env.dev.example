# =============================
# Polyglot Storage - Development
# =============================

NODE_ENV=development
PORT=3000
API_KEY=your-dev-api-key
DB_CLIENT=better-sqlite3
STAGING_TTL_SECONDS=1800
MAX_UPLOAD_SIZE_MB=10
LOG_LEVEL=debug

# GitHub Provider
GITHUB_TOKEN=your-dev-github-token
GITHUB_OWNER=your-dev-github-owner
GITHUB_REPO=your-dev-github-repo
GITHUB_BRANCH=main
GITHUB_UPLOAD_PATH=dev/assets

# Google Drive Provider
GOOGLE_CLIENT_ID=your-dev-google-client-id
GOOGLE_CLIENT_SECRET=your-dev-google-client-secret
GOOGLE_REFRESH_TOKEN=your-dev-google-refresh-token
GOOGLE_DRIVE_FOLDER_ID=your-dev-folder-id

