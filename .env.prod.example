# =============================
# Polyglot Storage - Production
# =============================

NODE_ENV=production
PORT=3000
API_KEY=your-production-api-key
DB_CLIENT=pg
DB_HOST=your-prod-db-host
DB_PORT=5432
DB_USER=your-prod-db-user
DB_PASSWORD=your-prod-db-password
DB_NAME=polyglot_storage
STAGING_TTL_SECONDS=1800
MAX_UPLOAD_SIZE_MB=10
LOG_LEVEL=info

# GitHub Provider
GITHUB_TOKEN=your-prod-github-token
GITHUB_OWNER=your-prod-github-owner
GITHUB_REPO=your-prod-github-repo
GITHUB_BRANCH=main
GITHUB_UPLOAD_PATH=prod/assets

# Google Drive Provider
GOOGLE_CLIENT_ID=your-prod-google-client-id
GOOGLE_CLIENT_SECRET=your-prod-google-client-secret
GOOGLE_REFRESH_TOKEN=your-prod-google-refresh-token
GOOGLE_DRIVE_FOLDER_ID=your-prod-folder-id
